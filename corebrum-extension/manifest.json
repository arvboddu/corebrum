{
  "manifest_version": 3,
  "name": "Corebrum Seamless Bridge",
  "version": "1.1",
  "permissions": ["tabCapture", "tabs", "offscreen"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "http://localhost:8001/*",
    "ws://localhost:8001/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' ws://localhost:8001 http://localhost:8001;"
  }
}
